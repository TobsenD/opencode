FROM node:25-trixie

RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
      git \
      curl \
      ca-certificates \
      ripgrep \
      fd-find \
      jq \
      yq \
      unzip \
      xz-utils \
      procps \
      python3 \
      python3-pip \
      python3-venv \
      build-essential \
      chromium \
      openssh-client \
      netcat-openbsd \
      iputils-ping \
      libcap2-bin \
    && \
    rm -rf /var/lib/apt/lists/* && \
    setcap cap_net_raw+p /usr/bin/ping
RUN curl -fsSL https://packages.buildkite.com/helm-linux/helm-debian/gpgkey | gpg --dearmor | tee /usr/share/keyrings/helm.gpg > /dev/null && \
    echo "deb [signed-by=/usr/share/keyrings/helm.gpg] https://packages.buildkite.com/helm-linux/helm-debian/any/ any main" | tee /etc/apt/sources.list.d/helm-stable-debian.list && \
    apt-get update &&\
    apt-get install helm -y --no-install-recommends && \
    rm -rf /var/lib/apt/lists/* 
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
RUN npm install -g opencode-ai playwright

ENV PATH="/root/.cargo/bin:/usr/local/lib/node_modules/opencode-ai/bin:${PATH}"

# Copy git validation script and set up host config mount point
COPY container/entrypoint-validate-git.sh /usr/local/bin/opencode-entrypoint
RUN chmod +x /usr/local/bin/opencode-entrypoint && \
    mkdir -p /root/.config.host

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/opencode-entrypoint"]
CMD ["opencode"]
